{
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@latest"
    }
  },
  "rewrites": [
    { "source": "/api/v1/(.*)", "destination": "/api/index.py" },
    { "source": "/api/(.*)", "destination": "/api/index.py" }
  ],
  "crons": [
    {
      "path": "/api/v1/admin/crawler/cron",
      "schedule": "0 2 * * *"
    }
  ]
}
