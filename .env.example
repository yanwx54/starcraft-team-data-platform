# ===========================================
# 韩国星际争霸团战数据自动采集与统计平台
# 环境变量配置示例
# ===========================================
# 使用说明：复制本文件为 .env，然后填写实际值
# cp .env.example .env
# ===========================================

# ---------- PostgreSQL 数据库 ----------
POSTGRES_DB=starcraft
POSTGRES_USER=starcraft
POSTGRES_PASSWORD=starcraft123
DB_PORT=5432

# ---------- FastAPI 后端 ----------
# 数据库连接URL
# Docker: postgresql://starcraft:starcraft123@starcraft-db:5432/starcraft
# Vercel: 使用 Neon 连接串，如 postgresql://user:pass@ep-xxx.neon.tech/starcraft?sslmode=require
DATABASE_URL=postgresql://starcraft:starcraft123@localhost:5432/starcraft

# 运行环境：development / production
ENVIRONMENT=development

# API服务端口
API_PORT=8000

# ---------- Vercel 部署 ----------
# Vercel Cron 定时采集密钥（自定义随机字符串）
CRON_SECRET=

# ---------- 翻译服务 ----------
# 翻译提供者（V1版本未使用AI翻译，预留字段）
TRANSLATION_PROVIDER=local

# OpenAI API Key（V1版本未使用，预留字段）
OPENAI_API_KEY=

# ---------- Vue3 前端 ----------
# 前端服务端口（HTTP）
WEB_PORT=80

# HTTPS端口
HTTPS_PORT=443

# ---------- SSL ----------
# 域名（用于Let's Encrypt证书申请）
DOMAIN=

# 通知邮箱（Let's Encrypt）
CERTBOT_EMAIL=
